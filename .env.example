# public-web | desktop
#
# public-web: builds the marketing site only — landing page, privacy policy,
#   and terms of use. The document editor,
#   templates, settings, and every other application route are blocked
#   server-side (see src/app/[locale]/(desktop)/layout.tsx) and are not
#   reachable by guessing a URL.
# desktop: builds the full product. This is what anvilnote-desktop packages
#   into the Electron app.
#
# Local development (`pnpm dev`) defaults to desktop when this is unset, as a
# convenience so existing workflows keep working without extra setup. A
# production build (`pnpm build`, `pnpm build:web`, `pnpm build:desktop`)
# always sets this explicitly via the script itself — see package.json.
NEXT_PUBLIC_ANVILNOTE_RUNTIME=desktop
